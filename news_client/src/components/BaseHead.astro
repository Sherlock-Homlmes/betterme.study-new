---
import { siteConfig } from "@/site-config";
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

export interface Props {
	title: string;
	description?: string;
	keywords: string[];
	ogImage?: string | undefined;
	articleDate?: string | undefined;
	createdAt: string;
	updatedAt: string | null;
	isExpired?: boolean | null;
}

const {
	title,
	description = siteConfig.description,
	ogImage,
	articleDate,
	keywords = [],
	createdAt,
	updatedAt,
	isExpired = false
} = Astro.props;

const ENVIRONMENT = import.meta.env.ENVIRONMENT;

//* SEO *//
// Canontical
let pathName = Astro.url.pathname;
const canonicalPathNameMap: Record<string, string> = {
	"/search": "/",
};
const canonicalURL = new URL(
	canonicalPathNameMap[pathName] ?? pathName,
	Astro.site,
);

// Media tag
const socialImageURL = new URL(ogImage ? ogImage : "/open-graph.png", Astro.url)
	.href;
const headKeyword = keywords.join(", ");
const siteTitle = `${title} • ${siteConfig.title}`;

// Schema
let schemaElement = null;
let schema = null;
const organization = {
  "@type": "Organization",
  "@id": "https://news.betterme.dev/#organization",
  name: "BetterMe",
  url: "https://news.betterme.dev",
  logo: {
    "@type": "ImageObject",
    url: "https://news.betterme.dev/favicon-180x180.png",
  },
  description: "BetterMe News - Trang thông tin về Câu lạc bộ, tình nguyện, học bổng, khóa học dành cho học sinh, sinh viên Việt Nam.",
  email: "contact@news.betterme.dev",
  sameAs: [
    "https://betterme.dev",
    "https://www.facebook.com/profile.php?id=61561787097897",
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: "26 ngõ 84 Yên Hòa",
    addressLocality: "Cầu Giấy",
    addressRegion: "Hà Nội",
    addressCountry: "VN", // ← fix "VI" → "VN"
    postalCode: "11300",
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: "contact@news.betterme.dev",
    contactType: "customer support",
  },
};

if (pathName.startsWith("/posts/")) {
  schema = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description: description,
    image: [socialImageURL],
    datePublished: createdAt,
    dateModified: updatedAt ?? createdAt,
    author: {
      "@type": "Person",
      name: "Tạ Minh Khôi",
      url: "https://muctim.tuoitre.vn/nam-sinh-gen-z-thanh-lap-cong-dong-ho-tro-hoc-tap-cho-nguoi-tre-64910.htm",
    },
    publisher: organization,
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `https://news.betterme.dev${pathName}`,
    },
  };
} else {
  schema = {
    "@context": "https://schema.org",
    "@graph": [
      organization,
      {
        "@type": "WebSite",
        "@id": "https://news.betterme.dev/#website",
        url: "https://news.betterme.dev",
        name: "BetterMe News",
        description: description,
        publisher: {
          "@id": "https://news.betterme.dev/#organization",
        },
        potentialAction: {
          "@type": "SearchAction",
          target: {
            "@type": "EntryPoint",
            urlTemplate:
              "https://news.betterme.dev/?search={search_term_string}",
          },
          "query-input": "required name=search_term_string",
        },
      },
    ],
  };
}
if (schema)
	schemaElement = `<script type="application/ld+json" is:raw>${JSON.stringify(schema, undefined, 4)}</script>`;
---

<!-- ViewTransitions  -->
<ViewTransitions />

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width,initial-scale=1' />
<link rel='apple-touch-icon' sizes='180x180' href='/favicon-180x180.png' />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
<!-- <link rel="manifest" href="/site.webmanifest"> -->
<meta name='generator' content={Astro.generator} />
{
	ENVIRONMENT === 'DEMO' && (
		<>
			<meta name='robots' content='noindex,nofollow' />
		</>
	)
}
{isExpired && (
	<meta name="robots" content="noindex, follow" />
)}
<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />
<meta http-equiv='content-language' content='vi' />

<!-- Meta tag -->
<meta name='title' content={siteTitle} />
<meta name='description' content={description} />
<meta name='author' content={siteConfig.author} />
<meta name='keywords' content={headKeyword} />

<!-- Schema -->
<Fragment set:html={schemaElement} />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={articleDate ? 'article' : 'website'} />
<meta property='og:url' content={canonicalURL} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={socialImageURL} />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
{
	articleDate && (
		<>
			<meta property='article:author' content={siteConfig.author} />
			<meta property='article:published_time' content={articleDate} />
		</>
	)
}
<meta property='og:locale' content='vi_VN' />

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:url' content={canonicalURL} />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={socialImageURL} />

<!-- Sitemap -->
<link rel='sitemap' href='/sitemap.xml' />

<!-- RSS auto-discovery -->
<link rel='alternate' type='application/rss+xml' title={siteConfig.title} href='/rss.xml' />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>
