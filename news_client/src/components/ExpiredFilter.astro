---
import { cn } from "@/utils";

const matchIsExpired = Astro.url.searchParams.get("match_is_expired");
const isNotExpired = matchIsExpired === "false";
const isAll = matchIsExpired === "true" || matchIsExpired === null;
const label = isNotExpired ? "Còn hạn" : "Tất cả";

const buildUrl = (value: string) => {
	const params = new URLSearchParams(Astro.url.searchParams);
	params.set("match_is_expired", value);
	params.set("page", "1");
	return `?${params}`;
};
---

<div class="relative inline-block" id="expired-filter">
	<button
		class="flex items-center gap-1 pb-2.5 text-sm font-medium text-gray-600 hover:text-gray-800 dark:text-gray-300 dark:hover:text-white transition-colors"
		onclick="document.getElementById('expired-dropdown').classList.toggle('hidden')"
	>
		<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="21" y1="6" x2="3" y2="6"/>
			<line x1="17" y1="12" x2="3" y2="12"/>
			<line x1="13" y1="18" x2="3" y2="18"/>
		</svg>
		<span>{label}</span>
		<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m6 9 6 6 6-6"/>
		</svg>
	</button>
	<div id="expired-dropdown" class="hidden absolute top-full left-0 z-50 mt-1 w-36 rounded-lg border border-gray-200 bg-white shadow-lg dark:border-gray-700 dark:bg-gray-800 overflow-hidden">
		<a
			href={buildUrl("false")}
			class={cn(
				"block px-3 py-2 text-sm transition-colors",
				isNotExpired
					? "bg-indigo-50 text-indigo-700 font-semibold dark:bg-indigo-900/40 dark:text-indigo-300"
					: "text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700"
			)}
		>
			Còn hạn
		</a>
		<a
			href={buildUrl("true")}
			class={cn(
				"block px-3 py-2 text-sm transition-colors",
				isAll
					? "bg-indigo-50 text-indigo-700 font-semibold dark:bg-indigo-900/40 dark:text-indigo-300"
					: "text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700"
			)}
		>
			Tất cả
		</a>
	</div>
</div>

<script>
document.addEventListener("click", (e) => {
	const filter = document.getElementById("expired-filter");
	const dropdown = document.getElementById("expired-dropdown");
	if (!filter || !dropdown) return;
	if (!filter.contains(e.target)) dropdown.classList.add("hidden");
});
</script>
