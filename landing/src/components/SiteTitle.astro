---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title">
  <span class="site-title-better">Better</span>Me
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    font-family: "Space Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #18181b;
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
    letter-spacing: -0.5px;
  }
  .site-title-better {
    color: hsl(41, 36%, 38%);
  }
</style>
