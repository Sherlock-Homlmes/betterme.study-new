---
const DISCORD_GUILD_ID = "880360143768924210";
const DISCORD_API = `https://discord.com/api/guilds/${DISCORD_GUILD_ID}/widget.json`;

let discordData: {
  name: string;
  presence_count: number;
  channels: { id: string; name: string }[];
  members: { channel_id: string; avatar_url: string; username: string }[];
  instant_invite: string;
} | null = null;

try {
  const res = await fetch(DISCORD_API);
  if (res.ok) {
    discordData = await res.json();
  }
} catch {}

const inviteLink = discordData?.instant_invite || "https://discord.gg/betterme";
---

<section class="about-section">
  <div class="container about-grid">
    <div class="about-content reveal">
      <h2 class="reveal">BetterMe là gì?</h2>
      <p>
        BetterMe là cộng đồng học tập và phát triển bản thân trực tuyến phi lợi
        nhuận. Từ một nhóm nhỏ những người yêu học tập, cộng đồng đã phát triển
        thành hệ sinh thái với hơn 18.500 thành viên hoạt động tích cực, trở
        thành đối tác chính thức của Discord và tổ chức nhiều sự kiện, cuộc thi
        cùng các chương trình chia sẻ kiến thức cho người Việt trên toàn thế
        giới.
      </p>

      <ul class="feature-list">
        <li class="feature-item">
          <span class="feature-icon">🎵</span>
          <div>
            <strong>Phòng học 24/7</strong>
            <p class="feature-desc">
              Các kênh thoại hoạt động 24/7 tích hợp bot phát nhạc chất lượng
              cao, tạo không gian học tập nhóm trực tuyến miễn phí bất cứ lúc
              nào.
            </p>
          </div>
        </li>
        <li class="feature-item">
          <span class="feature-icon">🍅</span>
          <div>
            <strong>Đồng hồ Pomodoro Timer</strong>
            <p class="feature-desc">
              Công cụ Pomodoro được tích hợp trực tiếp trên Discord và website,
              giúp bạn áp dụng phương pháp học tập khoa học để tối ưu hiệu suất
              tập trung mỗi ngày.
            </p>
          </div>
        </li>
        <li class="feature-item">
          <span class="feature-icon">🤖</span>
          <div>
            <strong>Trợ lý AI học tập</strong>
            <p class="feature-desc">
              Bot AI được tích hợp sẵn trong máy chủ Discord hỗ trợ giải đáp câu
              hỏi, tóm tắt tài liệu và gợi ý phương pháp học tập hiệu quả hoàn
              toàn miễn phí cho mọi thành viên.
            </p>
          </div>
        </li>
        <li class="feature-item">
          <span class="feature-icon">🤝</span>
          <div>
            <strong>Tìm "Study Buddy" tức thì</strong>
            <p class="feature-desc">
              Hệ thống ghép đôi học tập giúp bạn tìm được bạn học cùng mục tiêu,
              giám sát chéo và giữ vững kỷ luật học tập mỗi ngày.
            </p>
          </div>
        </li>
        <li class="feature-item">
          <span class="feature-icon">✨</span>
          <div>
            <strong>Phát triển toàn diện</strong>
            <p class="feature-desc">
              Không chỉ học tập, cộng đồng còn tập trung bồi dưỡng Thể chất,
              Tinh thần và Trí tuệ cho người Việt thông qua các câu lạc bộ, sự
              kiện và hoạt động tình nguyện.
            </p>
          </div>
        </li>
      </ul>
    </div>

    <div
      id="discord-widget-container"
      class="reveal stagger-2 discord-widget-wrapper"
    >
      {
        discordData ? (
          <div class="discord-mockup">
            <div class="discord-header">
              <div class="discord-title">
                <span class="pulse-dot" />
                <strong class="discord-server-name">
                  {discordData.name}
                </strong>
                <span class="discord-badge">
                  Discord's partner
                </span>
              </div>
              <span class="discord-online-count">
                {discordData.presence_count.toLocaleString()} Online
              </span>
            </div>

            <div class="voice-channels discord-channels-scroll">
              <div class="channel-title">
                {" "}
                Kênh Học Tập Hoạt Động
              </div>
              {(() => {
                let channelCount = 0;
                return (discordData!.channels || []).map((chan) => {
                  const activeMembers = (discordData!.members || []).filter(
                    (m) => m.channel_id === chan.id,
                  );
                  if (activeMembers.length === 0 && channelCount >= 3)
                    return null;
                  channelCount++;
                  return (
                    <div class="voice-channel">
                      <div class="voice-channel-header">
                        <div class="voice-channel-name">
                          <span class="pulse-dot" />
                          <span class="voice-channel-label">🔊 {chan.name}</span>
                        </div>
                        <span class="voice-channel-count">
                          {activeMembers.length} đang học
                        </span>
                      </div>
                      {activeMembers.length > 0 && (
                        <div class="voice-channel-members">
                          {activeMembers.slice(0, 5).map((m) => (
                            <div class="member-pill">
                              <img
                                src={m.avatar_url}
                                alt={m.username}
                                width="14"
                                height="14"
                                class="member-avatar"
                                loading="lazy"
                              />
                              <span class="member-name">
                                {m.username}
                              </span>
                            </div>
                          ))}
                          {activeMembers.length > 5 && (
                            <span class="member-overflow">
                              +{activeMembers.length - 5}
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  );
                });
              })()}
              <div class="discord-channels-hint">
                ✨ Còn nhiều phòng khác đang đợi bạn khám phá!
              </div>
            </div>

            <a
              href={inviteLink}
              target="_blank"
              class="btn btn-purple interactive discord-join-btn"
            >
              Gia Nhập Server Ngay
            </a>
          </div>
        ) : (
          <div class="discord-fallback">
            <iframe
              src={`https://discord.com/widget?id=${DISCORD_GUILD_ID}&theme=light`}
              width="100%"
              height="500"
              allowtransparency="true"
              frameborder="0"
              sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
              loading="lazy"
              title="BetterMe Community Discord Server"
            />
          </div>
        )
      }
    </div>
  </div>
</section>
