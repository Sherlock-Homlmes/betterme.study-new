---

<section class="hero">
  <div class="floating-decor decor-1">⏰</div>
  <div class="floating-decor decor-2">☕</div>
  <div class="floating-decor decor-3">📚</div>
  <div class="floating-decor decor-4">⭐️</div>

  <div class="container hero-content" style="position: relative;">
    <div
      class="hero-title-container"
      style="display: inline-flex; align-items: center; justify-content: center; gap: 20px; position: relative; flex-wrap: wrap;"
    >
      <h1 class="gradient-text reveal" style="margin-bottom: 0;">
        BetterMe - Better everyday
      </h1>
    </div>

    <p class="subtitle reveal stagger-1" style="margin-top: 16px;">
      Cộng đồng học tập và phát triển bản thân phi lợi nhuận số 1 Việt Nam
    </p>

    <div class="stats-strip reveal stagger-2">
      <div class="stat-item">
        <span class="stat-num" data-target="18500" style="padding-left: 15px"
          >18,500+</span
        >
        <span class="stat-item-label">Thành Viên</span>
      </div>
      <div class="stat-item">
        <span class="stat-num-stable" data-target="24/7">24/7</span>
        <span class="stat-item-label">Online</span>
      </div>
      <div class="stat-item stat-item-year">
        <span class="stat-num" data-target="2021">2,021</span>
        <span class="stat-item-label">Thành Lập</span>
      </div>
    </div>

    <div class="cinder-mobile-wrap">
      <div class="cinder-mobile-sprite"></div>
    </div>

    <div class="btn-group reveal stagger-3">
      <a
        href="https://discord.gg/betterme"
        target="_blank"
        class="btn btn-purple interactive"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 127.14 96.36"
          fill="currentColor"
          ><path
            d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0,-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58,-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63,-10.85,68.43,68.43,0,0,1,-10.51,-5A52.57,52.57,0,0,0,31,78.23a74.37,74.37,0,0,0,65.06,0,52.57,52.57,0,0,0,2.94,2.24,68.43,68.43,0,0,1,-10.51,5A77.7,77.7,0,0,0,95.15,96.36,105.73,105.73,0,0,0,126.11,77.53C129.54,49.49,120.72,26.75,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"
          ></path></svg
        >
        Tham gia Discord
      </a>
      <a href="#pomodoro-room" class="btn btn-outline-green interactive">
        Bắt đầu Pomodoro
      </a>
    </div>
  </div>
</section>
