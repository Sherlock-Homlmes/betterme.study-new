---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  readingTime: number;
}

const { title, description, pubDate, updatedDate, author, tags, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('vi-VN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('vi-VN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="blog-post-header">
  <div class="container">
    <div class="blog-post-tags">
      {tags.map(tag => (
        <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="blog-tag blog-tag-link">{tag}</a>
      ))}
    </div>
    <h1 class="blog-post-title">{title}</h1>
    <div class="blog-post-meta">
      <span class="blog-post-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {author}
      </span>
      <span class="blog-post-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {formattedDate}
      </span>
      <span class="blog-post-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {readingTime} phút đọc
      </span>
      {updatedDate && (
        <span class="blog-post-meta-item">
          (Cập nhật: {formattedUpdated})
        </span>
      )}
    </div>
  </div>
</header>
