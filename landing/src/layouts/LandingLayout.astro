---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
}

const { 
  title = 'Betterme-Cộng Đồng Học Tập Dành Cho Người Việt',
  description = 'BetterMe — cộng đồng học tập phi lợi nhuận lớn nhất Việt Nam. 18500+ thành viên, phòng học 24/7, Pomodoro, AI bot, tìm study buddy. Tham gia ngay!',
  canonicalURL = 'https://betterme.dev/',
} = Astro.props;

const ogImage = 'https://betterme.dev/og-image.png';
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg">
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="BetterMe" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "BetterMe Community",
      "url": "https://betterme.dev",
      "description": "Cộng đồng học tập phát triển bản thân người Việt trên Discord.",
      "foundingDate": "2021-08",
      "numberOfMembers": { "@type": "QuantitativeValue", "value": 18500 },
      "nonprofitStatus": "NonprofitType",
      "sameAs": ["https://discord.gg/betterme"],
      "areaServed": { "@type": "Country", "name": "Vietnam" },
      "availableLanguage": "Vietnamese"
    })} />

    <link rel="alternate" type="application/rss+xml" title="BetterMe" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="custom-cursor"></div>
    <canvas id="canvas-particles"></canvas>
    <Navbar />
    <main>
      <slot />
    </main>
    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
