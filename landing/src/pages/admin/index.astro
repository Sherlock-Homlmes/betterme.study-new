---
import '../../styles/global.css'
import { getCollection } from 'astro:content'

const blogPosts = await getCollection('blog')
const publishedPosts = blogPosts
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — BetterMe SEO Blog</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg:#faf9f6;--surface:#fff;--border:#e4e4e7;--text:#18181b;--muted:#71717a;
            --primary:#3f6212;--primary-lt:#4d7c0f;--danger:#dc2626;--danger-bg:#fef2f2;
            --warn:#d97706;--fh:"Space Grotesk",sans-serif;--fb:"Be Vietnam Pro",sans-serif;
            --r:8px;--sh:0 1px 3px rgba(0,0,0,.08);
        }
        *{box-sizing:border-box;margin:0;padding:0;cursor:auto}
        body{font-family:var(--fb);background:var(--bg);color:var(--text);min-height:100vh;cursor:auto}
        a,button,.btn,input,[onclick]{cursor:pointer}
        #custom-cursor,#canvas-particles{display:none!important}

        .nav{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
        .nav h1{font-family:var(--fh);font-size:1.25rem;font-weight:700}
        .nav h1 a{color:var(--text);text-decoration:none}
        .nav h1 span{color:var(--primary)}
        .nav-right{display:flex;gap:8px;align-items:center;font-size:.85rem;color:var(--muted)}

        .btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--text);font-family:var(--fb);font-size:.875rem;font-weight:500;cursor:pointer;transition:all .15s}
        .btn:hover{border-color:var(--muted)}
        .btn-p{background:var(--primary);color:#fff;border-color:var(--primary)}
        .btn-p:hover{background:var(--primary-lt)}
        .btn-d{color:var(--danger);border-color:var(--danger)}
        .btn-d:hover{background:var(--danger-bg)}
        .btn-sm{padding:4px 10px;font-size:.8rem}
        .btn:disabled{opacity:.5;cursor:not-allowed}

        .center{display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 56px)}
        .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:48px 40px;text-align:center;box-shadow:var(--sh);max-width:420px;width:100%}
        .card h2{font-family:var(--fh);font-size:1.5rem;margin-bottom:8px}
        .card p{color:var(--muted);font-size:.9rem;margin-bottom:24px}
        .card .f{text-align:left;margin-bottom:16px}
        .card label{display:block;font-size:.85rem;font-weight:500;margin-bottom:4px}
        .card input{width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:var(--r);font-family:var(--fb);font-size:.9rem;outline:none}
        .card input:focus{border-color:var(--primary)}
        .card .hint{font-size:.75rem;color:var(--muted);margin-top:4px}

        .wrap{max-width:1100px;margin:0 auto;padding:24px}
        .grid2{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px}
        .stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px}
        .stat .l{font-size:.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
        .stat .v{font-family:var(--fh);font-size:1.4rem;font-weight:700;margin-top:4px}

        .bar{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap;align-items:center}
        .bar .sp{flex:1}
        .bar input[type=text]{padding:8px 12px;border:1px solid var(--border);border-radius:var(--r);font-family:var(--fb);font-size:.875rem;width:220px;outline:none}
        .bar input:focus{border-color:var(--primary)}

        .tbl{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
        .row{display:grid;grid-template-columns:1fr 180px 100px 80px 120px;align-items:center;padding:14px 16px;border-bottom:1px solid var(--border);transition:background .1s}
        .row:last-child{border-bottom:none}
        .row:hover{background:#fafaf9}
        .row.hd{background:#f4f4f5;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--muted)}
        .row.hd:hover{background:#f4f4f5}
        .row .t{font-weight:500;font-size:.9rem}
        .row .s{font-size:.8rem;color:var(--muted);margin-top:2px}
        .row .kw{font-size:.8rem;color:var(--primary);background:rgba(63,98,18,.06);padding:2px 8px;border-radius:4px;display:inline-block}
        .row .d{font-size:.8rem;color:var(--muted)}
        .row .cost{font-size:.8rem;color:var(--warn)}
        .row .act{display:flex;gap:4px;justify-content:flex-end}

        .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;align-items:center;justify-content: center}
        .overlay.on{display:flex}
        .modal{background:var(--surface);border-radius:12px;padding:24px;max-width:480px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.15)}
        .modal.wide{max-width:720px}
        .modal h3{font-family:var(--fh);font-size:1.15rem;margin-bottom:16px}
        .modal .foot{display:flex;gap:8px;justify-content:flex-end;margin-top:20px}

        .toasts{position:fixed;top:72px;right:24px;z-index:300;display:flex;flex-direction:column;gap:8px}
        .toast{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px 16px;box-shadow:var(--sh);font-size:.875rem;animation:si .2s ease;max-width:360px}
        .toast.ok{border-left:3px solid var(--primary)}
        .toast.err{border-left:3px solid var(--danger)}
        .toast.info{border-left:3px solid var(--warn)}
        @keyframes si{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}

        .empty{text-align:center;padding:64px 24px;color:var(--muted)}
        .spin{display:inline-block;width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:sp .6s linear infinite}
        @keyframes sp{to{transform:rotate(360deg)}}
        .hidden{display:none!important}

        .wf-list{max-height:300px;overflow-y:auto}
        .wf-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:.85rem}
        .wf-item:last-child{border-bottom:none}
        .wf-badge{padding:2px 8px;border-radius:4px;font-size:.75rem;font-weight:600}
        .wf-badge.running{background:#dbeafe;color:#1d4ed8}
        .wf-badge.complete{background:#dcfce7;color:#166534}
        .wf-badge.failed{background:var(--danger-bg);color:var(--danger)}

        /* ─── Editor modal ─── */
        #m-prev{position:fixed;inset:0;z-index:200;display:none;background:var(--surface)}
        #m-prev.on{display:flex}
        .editor-wrap{display:flex;flex-direction:column;width:100%;height:100vh}
        .editor-bar{display:flex;align-items:center;gap:8px;padding:8px 16px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0}
        .editor-bar h3{font-family:var(--fh);font-size:1rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
        .editor-bar .slug{font-size:.75rem;color:var(--muted);margin-right:4px}
        .editor-body{display:flex;flex:1;overflow:hidden}
        .editor-src{width:50%;display:flex;flex-direction:column;border-right:1px solid var(--border);background:#1e1e2e}
        .editor-src label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:#6c7086;padding:8px 12px 4px;background:#1e1e2e}
        #ed-ta{flex:1;width:100%;border:none;outline:none;resize:none;padding:12px;font-family:'JetBrains Mono','Fira Code',monospace;font-size:.82rem;line-height:1.7;background:#1e1e2e;color:#cdd6f4;tab-size:4}
        #ed-ta::placeholder{color:#585b70}
        .editor-view{width:50%;overflow:hidden}
        .editor-view iframe{width:100%;height:100%;border:none}
        .ed-status{font-size:.72rem;color:var(--muted)}
        .ed-status.dirty{color:var(--warn)}
        .ed-status.saved{color:var(--primary)}
    </style>
</head>
<body>
    <nav class="nav">
        <h1><a href="/admin"><span>Better</span>Me SEO</a></h1>
        <div class="nav-right" id="nav-right"></div>
    </nav>

    <!-- ─── Login ─── -->
    <div id="view-login" class="center">
        <div class="card">
            <h2>SEO Admin</h2>
            <p>Nhập URL và Secret để kết nối worker</p>
            <div class="f"><label>Worker URL</label><input id="in-url" placeholder="https://ai-seo-worker.betterme.dev" /><div class="hint">Cloudflare worker URL</div></div>
            <div class="f"><label>Secret Key</label><input type="password" id="in-key" placeholder="x-internal-secret" /><div class="hint">INTERNAL_SECRET</div></div>
            <button class="btn btn-p" style="margin-top:8px" onclick="doLogin()">Kết nối</button>
        </div>
    </div>

    <!-- ─── Dashboard ─── -->
    <div id="view-dash" class="wrap hidden">
        <div class="grid2" id="stats"></div>
        <div class="bar">
            <button class="btn btn-p" onclick="openGen()">+ Generate</button>
            <button class="btn" onclick="loadArticles()">↻ Refresh</button>
            <button class="btn" onclick="openWorkflows()">Workflows</button>
            <div class="sp"></div>
            <input type="text" placeholder="Tìm bài..." id="q" oninput="filter()" />
        </div>
        <div class="tbl" id="tbl">
            <div class="row hd"><div>Bài viết</div><div>Keyword</div><div>Ảnh</div><div>Chi phí</div><div style="text-align:right">Thao tác</div></div>
        </div>
        <div id="empty" class="empty hidden"><p>Chưa có bài nào</p><button class="btn btn-p" onclick="openGen()">Generate bài đầu</button></div>

        <!-- ─── Published Blog Posts ─── -->
        <h2 style="font-family:var(--fh);font-size:1.15rem;margin:32px 0 12px;font-weight:700">Published Blog Posts</h2>
        <div class="tbl">
            <div class="row hd"><div>Bài viết</div><div>Tác giả</div><div>Ngày đăng</div><div>Tags</div><div style="text-align:right">Link</div></div>
            {publishedPosts.length === 0 && <div class="empty" style="padding:32px"><p>Chưa có bài nào được publish</p></div>}
            {publishedPosts.map(post => (
                <div class="row">
                    <div>
                        <div class="t">{post.data.title}</div>
                        <div class="s">{post.id}</div>
                    </div>
                    <div class="d">{post.data.author || 'BetterMe'}</div>
                    <div class="d">{post.data.pubDate.toLocaleDateString('vi-VN')}</div>
                    <div>
                        {post.data.tags.slice(0, 3).map((tag: string) => (
                            <span class="kw" style="margin:1px 2px">{tag}</span>
                        ))}
                    </div>
                    <div class="act">
                        <a class="btn btn-sm" href={`/blog/${post.id}`} target="_blank">👁</a>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- ─── Generate modal ─── -->
    <div class="overlay" id="m-gen">
        <div class="modal">
            <h3>Generate bài mới</h3>
            <p style="color:var(--muted);font-size:.85rem;margin-bottom:16px">Workflow: research → viết → ảnh → R2. ~10-15 phút/bài.</p>
            <label style="font-size:.85rem;font-weight:500;display:block;margin-bottom:6px">Số bài</label>
            <input type="number" id="gen-n" value="1" min="1" max="10" style="padding:8px 12px;border:1px solid var(--border);border-radius:var(--r);font-size:.9rem;width:100px;font-family:var(--fb)" />
            <div class="foot"><button class="btn" onclick="closeM('m-gen')">Hủy</button><button class="btn btn-p" id="btn-gen" onclick="doGen()">Tạo</button></div>
        </div>
    </div>

    <!-- ─── Delete modal ─── -->
    <div class="overlay" id="m-del">
        <div class="modal">
            <h3>Xóa bài viết?</h3>
            <p id="del-text" style="color:var(--muted);font-size:.9rem"></p>
            <p style="color:var(--danger);font-size:.85rem;margin-top:8px">Xóa bài + ảnh + vector. Không hoàn tác.</p>
            <div class="foot"><button class="btn" onclick="closeM('m-del')">Hủy</button><button class="btn btn-d" id="btn-del">Xóa</button></div>
        </div>
    </div>

    <!-- ─── Editor modal ─── -->
    <div id="m-prev">
        <div class="editor-wrap">
            <div class="editor-bar">
                <h3 id="prev-t">Editor</h3>
                <span class="slug" id="ed-slug"></span>
                <span class="ed-status" id="ed-status"></span>
                <button class="btn btn-sm" id="btn-save" onclick="saveEdit()">💾 Save</button>
                <button class="btn btn-sm btn-p" onclick="publishFromEditor()">🚀 Publish</button>
                <button class="btn btn-sm" onclick="closeM('m-prev')">✕ Đóng</button>
            </div>
            <div class="editor-body">
                <div class="editor-src">
                    <label>Markdown</label>
                    <textarea id="ed-ta" spellcheck="false" placeholder="Loading..."></textarea>
                </div>
                <div class="editor-view">
                    <iframe id="ed-frame" src="/admin/preview"></iframe>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── Workflows modal ─── -->
    <div class="overlay" id="m-wf">
        <div class="modal">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px"><h3>Workflows</h3><button class="btn btn-sm" onclick="closeM('m-wf')">Đóng</button></div>
            <div class="wf-list" id="wf-list"><p style="color:var(--muted)"><span class="spin"></span> Đang tải...</p></div>
        </div>
    </div>

    <div class="toasts" id="toasts"></div>

    <script>
        let articles = []
        let delSlug = null
        let editorSlug = null
        let originalContent = ''
        let wUrl = ''
        let wKey = ''

        const COOKIE = 'seo_admin'
        let previewTimer = null

        ;(function() {
            const c = getCookie(COOKIE)
            if (c) { try { const d = JSON.parse(c); wUrl = d.u || ''; wKey = d.k || '' } catch {} }
            document.getElementById('in-url').value = wUrl
            document.getElementById('in-key').value = wKey
            if (wUrl && wKey) ping()
        })()

        function getCookie(n) { const m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)')); return m ? decodeURIComponent(m[2]) : '' }
        function setCookie(n, v, days = 365) { const d = new Date(); d.setDate(d.getDate() + days); document.cookie = `${n}=${encodeURIComponent(v)}; expires=${d.toUTCString()}; path=/` }
        function rmCookie(n) { document.cookie = `${n}=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/` }

        function H() { return { 'Content-Type': 'application/json', 'x-internal-secret': wKey } }

        async function ping() {
            try {
                const r = await fetch(`${wUrl}/ping`)
                if (!r.ok) throw 0
                const d = await r.json()
                if (d.ok) { setCookie(COOKIE, JSON.stringify({ u: wUrl, k: wKey })); showDash(); return }
            } catch {}
            toast('Kết nối thất bại', 'err')
        }

        async function doLogin() {
            wUrl = document.getElementById('in-url').value.trim()
            wKey = document.getElementById('in-key').value.trim()
            if (!wUrl || !wKey) { toast('Nhập đủ URL và Key', 'err'); return }
            await ping()
        }

        function showDash() {
            document.getElementById('view-login').classList.add('hidden')
            document.getElementById('view-dash').classList.remove('hidden')
            document.getElementById('nav-right').innerHTML = `<span>${esc(wUrl.replace(/https?:\/\//, ''))}</span><button class="btn btn-sm" onclick="logout()">Logout</button>`
            loadArticles()
        }

        function logout() {
            rmCookie(COOKIE); wUrl = ''; wKey = ''
            document.getElementById('view-login').classList.remove('hidden')
            document.getElementById('view-dash').classList.add('hidden')
            document.getElementById('nav-right').innerHTML = ''
        }

        // ─── Articles ───
        async function loadArticles() {
            const tbl = document.getElementById('tbl')
            tbl.querySelectorAll('.row:not(.hd)').forEach(r => r.remove())
            try {
                const r = await fetch(`${wUrl}/articles`, { headers: H() })
                if (!r.ok) throw new Error(`HTTP ${r.status}`)
                const d = await r.json()
                articles = d.articles || []
                const totalCost = articles.reduce((s, a) => s + (a.cost?.estimatedUsd || 0), 0)
                const totalImg = articles.reduce((s, a) => s + (a.imageCount || 0), 0)
                document.getElementById('stats').innerHTML = `
                    <div class="stat"><div class="l">Tổng bài</div><div class="v">${articles.length}</div></div>
                    <div class="stat"><div class="l">Tổng ảnh</div><div class="v">${totalImg}</div></div>
                    <div class="stat"><div class="l">Tổng chi phí</div><div class="v">$${totalCost.toFixed(2)}</div></div>
                `
                const empty = document.getElementById('empty')
                if (!articles.length) { empty.classList.remove('hidden'); return }
                empty.classList.add('hidden')
                renderRows(articles)
            } catch (e) { toast('Lỗi: ' + e.message, 'err') }
        }

        function renderRows(list) {
            const tbl = document.getElementById('tbl')
            tbl.querySelectorAll('.row:not(.hd)').forEach(r => r.remove())
            list.forEach(a => {
                const date = a.publishedAt ? new Date(a.publishedAt).toLocaleDateString('vi-VN') : '—'
                const cost = a.cost?.estimatedUsd ? `$${a.cost.estimatedUsd}` : '—'
                const row = document.createElement('div')
                row.className = 'row'
                row.dataset.q = `${a.title} ${a.slug} ${a.primaryKeyword}`.toLowerCase()
                row.innerHTML = `
                    <div><div class="t">${esc(a.title)}</div><div class="s">${esc(a.slug)}</div></div>
                    <div><span class="kw">${esc(a.primaryKeyword)}</span></div>
                    <div class="d">${a.imageCount || 0} ảnh</div>
                    <div class="cost">${cost}</div>
                    <div class="act">
                        <button class="btn btn-sm" onclick="openEditor('${esc(a.slug)}')">✎</button>
                        <button class="btn btn-sm" onclick="publish('${esc(a.slug)}')" title="Publish to blog">🚀</button>
                        <button class="btn btn-sm" onclick="regen('${esc(a.slug)}')">↻</button>
                        <button class="btn btn-sm btn-d" onclick="openDel('${esc(a.slug)}','${esc(a.title)}')">✕</button>
                    </div>
                `
                tbl.appendChild(row)
            })
        }

        function filter() {
            const q = document.getElementById('q').value.toLowerCase()
            document.querySelectorAll('.row:not(.hd)').forEach(r => { r.style.display = r.dataset.q.includes(q) ? '' : 'none' })
        }

        // ─── Generate ───
        function openGen() { document.getElementById('m-gen').classList.add('on') }

        async function doGen() {
            const n = parseInt(document.getElementById('gen-n').value) || 1
            const btn = document.getElementById('btn-gen')
            btn.disabled = true; btn.innerHTML = '<span class="spin"></span> Đang tạo...'
            try {
                const r = await fetch(`${wUrl}/articles`, { method: 'POST', headers: H(), body: JSON.stringify({ targetCount: n }) })
                const d = await r.json()
                if (r.ok) { toast(`Workflow: ${d.workflowId}`, 'ok'); closeM('m-gen') }
                else toast('Lỗi: ' + (d.error || '?'), 'err')
            } catch (e) { toast('Lỗi: ' + e.message, 'err') }
            finally { btn.disabled = false; btn.textContent = 'Tạo' }
        }

        // ─── Publish ───
        async function publish(slug) {
            if (!confirm(`Publish "${slug}" to blog? Copy images + commit to GitHub.`)) return
            toast(`Đang publish "${slug}"...`, 'info')
            try {
                const r = await fetch(`${wUrl}/publish`, { method: 'POST', headers: H(), body: JSON.stringify({ slug }) })
                const d = await r.json()
                if (d.ok) { toast(`Published "${slug}"!`, 'ok') }
                else toast('Fail: ' + (d.error || '?'), 'err')
            } catch (e) { toast('Lỗi: ' + e.message, 'err') }
        }

        async function publishFromEditor() {
            if (!editorSlug) return
            const ta = document.getElementById('ed-ta')
            if (ta.value !== originalContent) {
                toast('Phải Save trước khi Publish', 'err')
                return
            }
            await publish(editorSlug)
        }

        // ─── Regenerate ───
        async function regen(slug) {
            if (!confirm(`Regenerate "${slug}"?`)) return
            toast(`Đang regenerate "${slug}"...`, 'info')
            try {
                const r = await fetch(`${wUrl}/articles/${slug}/_regenerate`, { method: 'POST', headers: H(), body: JSON.stringify({}) })
                const d = await r.json()
                if (d.ok) { toast(`OK!`, 'ok'); loadArticles() }
                else toast('Fail: ' + (d.error || '?'), 'err')
            } catch (e) { toast('Lỗi: ' + e.message, 'err') }
        }

        // ─── Delete ───
        function openDel(slug, title) {
            delSlug = slug
            document.getElementById('del-text').textContent = `"${title}" (${slug})`
            document.getElementById('m-del').classList.add('on')
            document.getElementById('btn-del').onclick = doDel
        }

        async function doDel() {
            if (!delSlug) return
            const btn = document.getElementById('btn-del')
            btn.disabled = true; btn.textContent = 'Đang xóa...'
            try {
                const r = await fetch(`${wUrl}/articles/${delSlug}`, { method: 'DELETE', headers: H() })
                const d = await r.json()
                if (d.ok) { toast('Đã xóa', 'ok'); closeM('m-del'); loadArticles() }
                else toast('Fail: ' + (d.error || '?'), 'err')
            } catch (e) { toast('Lỗi: ' + e.message, 'err') }
            finally { btn.disabled = false; btn.textContent = 'Xóa' }
        }

        // ─── Editor ───
        function sendToPreview(content) {
            const frame = document.getElementById('ed-frame')
            frame.contentWindow.postMessage({ type: 'seo-preview-update', content }, '*')
        }

        async function openEditor(slug) {
            editorSlug = slug
            const ta = document.getElementById('ed-ta')
            const status = document.getElementById('ed-status')
            const slugEl = document.getElementById('ed-slug')

            ta.value = ''
            status.textContent = ''
            status.className = 'ed-status'
            slugEl.textContent = slug
            document.getElementById('prev-t').textContent = slug
            document.getElementById('m-prev').classList.add('on')

            try {
                const r = await fetch(`${wUrl}/articles/${slug}`, { headers: H() })
                if (!r.ok) throw new Error('HTTP ' + r.status)
                const d = await r.json()
                const content = d.content || ''
                ta.value = content
                originalContent = content
                document.getElementById('prev-t').textContent = d.title || slug

                sessionStorage.setItem('seo_preview', JSON.stringify({ content }))
                const frame = document.getElementById('ed-frame')
                frame.src = '/admin/preview'

                status.textContent = 'Đã tải ✓'
                status.className = 'ed-status saved'
            } catch (e) {
                toast('Lỗi: ' + e.message, 'err')
            }
        }

        document.getElementById('ed-ta').addEventListener('input', function() {
            clearTimeout(previewTimer)
            const md = this.value
            previewTimer = setTimeout(() => {
                sendToPreview(md)
                const status = document.getElementById('ed-status')
                if (md !== originalContent) {
                    status.textContent = 'Chưa lưu ●'
                    status.className = 'ed-status dirty'
                } else {
                    status.textContent = 'Đã lưu ✓'
                    status.className = 'ed-status saved'
                }
            }, 400)
        })

        document.getElementById('ed-ta').addEventListener('keydown', function(e) {
            if (e.key === 'Tab') {
                e.preventDefault()
                const s = this.selectionStart
                const end = this.selectionEnd
                this.value = this.value.substring(0, s) + '    ' + this.value.substring(end)
                this.selectionStart = this.selectionEnd = s + 4
                this.dispatchEvent(new Event('input'))
            }
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault()
                saveEdit()
            }
        })

        async function saveEdit() {
            if (!editorSlug) return
            const ta = document.getElementById('ed-ta')
            const content = ta.value
            const btn = document.getElementById('btn-save')
            const status = document.getElementById('ed-status')

            btn.disabled = true; btn.textContent = '⏳...'
            try {
                const r = await fetch(`${wUrl}/articles/${editorSlug}`, {
                    method: 'PATCH',
                    headers: H(),
                    body: JSON.stringify({ content }),
                })
                const d = await r.json()
                if (r.ok) {
                    originalContent = content
                    status.textContent = 'Đã lưu ✓'
                    status.className = 'ed-status saved'
                    toast('Đã lưu', 'ok')
                } else {
                    toast('Lỗi: ' + (d.error || '?'), 'err')
                }
            } catch (e) {
                toast('Lỗi: ' + e.message, 'err')
            } finally {
                btn.disabled = false; btn.textContent = '💾 Save'
            }
        }

        // ─── Workflows ───
        async function openWorkflows() {
            document.getElementById('wf-list').innerHTML = '<p style="color:var(--muted)"><span class="spin"></span> Đang tải...</p>'
            document.getElementById('m-wf').classList.add('on')
            try {
                const r = await fetch(`${wUrl}/article-workflows`, { headers: H() })
                const d = await r.json()
                const wfs = d.workflows || []
                if (!wfs.length) { document.getElementById('wf-list').innerHTML = '<p style="color:var(--muted)">Không có workflow nào gần đây</p>'; return }
                document.getElementById('wf-list').innerHTML = wfs.map(w => `
                    <div class="wf-item">
                        <div><strong>${esc(w.id)}</strong><br><span style="font-size:.75rem;color:var(--muted)">${w.triggerDate} · ${w.targetCount} bài</span></div>
                        <span class="wf-badge ${w.status === 'complete' ? 'complete' : w.status === 'failed' ? 'failed' : 'running'}">${w.status}</span>
                    </div>
                `).join('')
            } catch (e) { document.getElementById('wf-list').innerHTML = `<p style="color:var(--danger)">${e.message}</p>` }
        }

        function closeM(id) { document.getElementById(id).classList.remove('on'); delSlug = null; editorSlug = null }
        document.querySelectorAll('.overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('on') }))

        function toast(msg, type = 'info') { const c = document.getElementById('toasts'); const el = document.createElement('div'); el.className = `toast ${type}`; el.textContent = msg; c.appendChild(el); setTimeout(() => el.remove(), 5000) }
        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML }

        window.doLogin = doLogin; window.logout = logout; window.loadArticles = loadArticles; window.filter = filter
        window.openGen = openGen; window.doGen = doGen; window.regen = regen; window.publish = publish; window.openDel = openDel
        window.openEditor = openEditor; window.saveEdit = saveEdit; window.publishFromEditor = publishFromEditor
        window.openWorkflows = openWorkflows; window.closeM = closeM
    </script>
</body>
</html>
