---
const cookieDomain = import.meta.env.PUBLIC_COOKIE_DOMAIN || ".betterme.dev";
const apiUrl = import.meta.env.PUBLIC_API_URL || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logging in...</title>
  </head>
  <body>
    <p id="status">Logging in...</p>
    <script define:vars={{ cookieDomain, apiUrl }}>
      (async () => {
        const statusEl = document.getElementById("status");
        const params = new URLSearchParams(window.location.search);
        const code = params.get("code");
        const redirect = params.get("redirect");

        const redirectMap = {
          pomodoro: "https://pomodoro.betterme.dev",
          news: "https://news.betterme.dev",
        };
        const redirectUrl = redirectMap[redirect] || "https://betterme.dev";

        const failUrl = `/auth/login-fail?redirect=${encodeURIComponent(redirect || "")}`;

        if (!code) {
          window.location.href = failUrl;
          return;
        }

        fetch(
          `${apiUrl}/api/auth/discord-oauth?code=${encodeURIComponent(code)}`
        )
          .then(async (res) => {
            if (!res.ok) {
              window.location.href = failUrl;
              return;
            }
            const data = await res.json();
            if (data?.token) {
              const expires = new Date();
              expires.setDate(expires.getDate() + 30);
              console.log(data.token);
              document.cookie = `Authorization=${data.token}; expires=${expires.toUTCString()}; path=/; domain=${cookieDomain}; SameSite=Lax`;
              window.location.href = redirectUrl;
            } else {
              window.location.href = failUrl;
            }
          })
          .catch((err) => {
            console.log(err);
            // window.location.href = failUrl;
          });
      })();
    </script>
  </body>
</html>
