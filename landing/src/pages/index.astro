---
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import WaveDivider from '../components/WaveDivider.astro';
import AboutSection from '../components/AboutSection.astro';
import PomodoroSection from '../components/PomodoroSection.astro';
import FooterCTA from '../components/FooterCTA.astro';
import '../styles/index.css';
---

<LandingLayout>
  <Hero />
  <MarqueeStrip />
  <WaveDivider />
  <AboutSection />
  <WaveDivider reversed />
  <MarqueeStrip class="marquee-rotated" />
  <PomodoroSection />
  <FooterCTA />
</LandingLayout>
